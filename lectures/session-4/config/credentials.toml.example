# Alpaca Paper Trading API Credentials
# 1. Sign up at https://alpaca.markets and create one or more paper trading accounts.
# 2. Generate an API key + secret for EACH paper account in the Alpaca dashboard
#    under "Paper Trading". The key pair is the account selector — every REST call
#    is routed to the account whose key pair is in the request headers. There is
#    no separate account_id parameter.
# 3. Copy this file to credentials.toml and fill in your keys:
#       cp credentials.toml.example credentials.toml
# 4. NEVER commit credentials.toml to git (it is gitignored).
#
# Multi-account usage: add one named table per paper account and select it at
# call time with the `section` kwarg:
#
#   client = Alpaca.load_client(CREDENTIALS_PATH; section = "paper_production")
#
# The default section name is "Credentials" (the single-account case below).

[Credentials]
endpoint = "https://paper-api.alpaca.markets"
key = "PASTE_YOUR_API_KEY_HERE"
secret = "PASTE_YOUR_API_SECRET_HERE"

# [paper_research]
# endpoint = "https://paper-api.alpaca.markets"
# key = "PASTE_RESEARCH_KEY"
# secret = "PASTE_RESEARCH_SECRET"
#
# [paper_production]
# endpoint = "https://paper-api.alpaca.markets"
# key = "PASTE_PRODUCTION_KEY"
# secret = "PASTE_PRODUCTION_SECRET"
