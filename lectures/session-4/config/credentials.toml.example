# Alpaca Paper Trading API Credentials
# 1. Sign up at https://alpaca.markets and create a paper trading account
# 2. Generate API keys in your dashboard under "Paper Trading"
# 3. Copy this file to credentials.toml and fill in your keys:
#       cp credentials.toml.example credentials.toml
# 4. NEVER commit credentials.toml to git (it is gitignored)

[Credentials]
endpoint = "https://paper-api.alpaca.markets"
key = "PASTE_YOUR_API_KEY_HERE"
secret = "PASTE_YOUR_API_SECRET_HERE"
